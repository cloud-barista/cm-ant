# cm-ant standalone docker-compose 환경변수 — 개발/테스트용
#
# 사용법:
#   1. cp .env.example .env
#   2. 운영 시에는 SPIDER/TB/TERRARIUM PASSWORD 등 시크릿을 환경에 맞게 교체
#   3. docker compose up -d
#
# 보안:
#   - 실제 .env는 .gitignore로 제외 (시크릿 커밋 금지)
#   - 본 example의 "default" 값은 dev/test 편의용
# 기준: cmig-workflow conf/cm-mayfly-default-env.yaml (single source of truth)

# =========================================================
# Required — docker-compose의 ${VAR:?}로 강제 검증되는 항목
# =========================================================

# cb-spider 0.12.6+ 강제 인증
SPIDER_USERNAME=default
SPIDER_PASSWORD=default

# cb-tumblebug 0.12.x REST API 인증 (평문, cm-mayfly 라인업과 정합)
TB_API_USERNAME=default
TB_API_PASSWORD=default

# mc-terrarium REST API 인증
TERRARIUM_API_USERNAME=default
TERRARIUM_API_PASSWORD=default

# =========================================================
# Optional — 비어 있으면 OpenBao 통합이 비활성된다
# =========================================================
VAULT_TOKEN=cmant-dev-token
